#!/bin/bash

set -ex

mkdir -p ${BOSH_INSTALL_TARGET}/src
mv * ${BOSH_INSTALL_TARGET}/src
mv ${BOSH_INSTALL_TARGET}/src .

source /var/vcap/packages/golang-*-linux/bosh/compile.env

mkdir ${BOSH_INSTALL_TARGET}/bin
export GOBIN=${BOSH_INSTALL_TARGET}/bin

pushd src/code.cloudfoundry.org
  go build -o "${BOSH_INSTALL_TARGET}/bin/gorouter" code.cloudfoundry.org/gorouter/cmd/gorouter
  go build -o "${BOSH_INSTALL_TARGET}/bin/config-validator" code.cloudfoundry.org/gorouter/cmd/config-validator
popd

# install jq
tar -xzf src/jq/jq-*.tgz -C ${BOSH_INSTALL_TARGET}/bin jq

chmod +x ${BOSH_INSTALL_TARGET}/bin/jq
