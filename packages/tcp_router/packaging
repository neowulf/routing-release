set -ex

mkdir -p ${BOSH_INSTALL_TARGET}/src
mv * ${BOSH_INSTALL_TARGET}/src
mv ${BOSH_INSTALL_TARGET}/src .

source /var/vcap/packages/golang-*-linux/bosh/compile.env

mkdir ${BOSH_INSTALL_TARGET}/bin
export GOBIN=${BOSH_INSTALL_TARGET}/bin

pushd src/code.cloudfoundry.org
  go build -o "${BOSH_INSTALL_TARGET}/bin/cf-tcp-router" code.cloudfoundry.org/cf-tcp-router/cmd/cf-tcp-router
  go build -o "${BOSH_INSTALL_TARGET}/bin/config-validator" code.cloudfoundry.org/cf-tcp-router/cmd/config-validator
popd
